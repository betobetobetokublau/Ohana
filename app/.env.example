# ───────────────────────────────────────────────────────────────────────────
#  Ohana — variables de entorno
#  Copia este archivo como .env.local y llena los valores.
#  En Vercel: agregar como Environment Variables del proyecto.
# ───────────────────────────────────────────────────────────────────────────

# ─── Supabase ──────────────────────────────────────────────────────────────
# Project URL · ej. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key · viene en Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key · ojo: SOLO server-side. Nunca exponer al cliente.
# Viene en Settings → API → Project API keys
SUPABASE_SERVICE_ROLE_KEY=

# Pooler connection string (transaction mode, puerto 6543)
# Settings → Database → Connection string → Transaction
# Necesaria para serverless functions y migrations vía CLI.
DATABASE_URL=

# Direct connection string (puerto 5432) · para migraciones de Supabase CLI.
DIRECT_URL=

# ─── Anthropic / Claude ────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── Postmark (Phase 4 · email worker) ─────────────────────────────────────
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=hola@ohana.app

# ─── App config ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret · cualquier string aleatorio, usado por Vercel Cron headers
CRON_SECRET=
